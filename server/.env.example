PORT=3000

# RPC URL for Solana cluster (e.g. devnet, mainnet-beta, localnet)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Oracle wallet private key represented as a JSON array of 64 numbers
ORACLE_PRIVATE_KEY=[1,2,3,4,5,...]

# The wallet address the payee/payer needs to send the x402 payment to
ORACLE_WALLET_ADDRESS=YourOraclePublicKeyHere
